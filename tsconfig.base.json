{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "baseUrl": ".",
    "paths": {
      "@skervik/core": ["./packages/core/src/index.ts"],
      "@skervik/protocol": ["./packages/protocol/src/index.ts"],
      "@skervik/server": ["./packages/server/src/index.ts"],
      "@skervik/client": ["./packages/client/src/index.ts"],
      "@skervik/bots": ["./packages/bots/src/index.ts"]
    }
  }
}
